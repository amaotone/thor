#!/usr/bin/env sh
set -e

if command -v lefthook >/dev/null 2>&1; then
  exec lefthook run prepare-commit-msg "$@"
fi

if [ -x "./node_modules/.bin/lefthook" ]; then
  exec ./node_modules/.bin/lefthook run prepare-commit-msg "$@"
fi

echo "Warning: lefthook not found, falling back to bd prepare-commit-msg hook" >&2
exec bd hooks run prepare-commit-msg "$@"
