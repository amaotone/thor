{
  "name": "thor-dev",
  "version": "0.1.0",
  "description": "Personal AI assistant for Discord with Claude Code, Codex, and Gemini backends",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check src/ tests/",
    "check:fix": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "biome check --write"
    ]
  },
  "keywords": [
    "ai",
    "agent",
    "discord",
    "claude-code"
  ],
  "author": "amaotone",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.16.3",
    "node-cron": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "lefthook": "^2.1.1",
    "lint-staged": "^16.2.7",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
